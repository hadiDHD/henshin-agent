  <units xsi:type="henshin:Rule" xmi:id="_createClassWithFeature" name="createClassWithFeature">
    <parameters xmi:id="_className" name="className" kind="IN">
      <type xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </parameters>
    <parameters xmi:id="_featureName" name="featureName" kind="IN">
      <type xsi:type="ecore:EDataType" href="http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </parameters>
    <lhs xmi:id="_createClass_LHS" name="Lhs">
      <nodes xmi:id="_lhs_root_c" name="root" outgoing="_lhs_root_to_feature_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel"/>
      </nodes>
      <nodes xmi:id="_lhs_feature_c" name="feature" incoming="_lhs_root_to_feature_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//Feature"/>
        <attributes xmi:id="_lhs_feature_name_c" value="featureName">
          <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//NamedElement/name"/>
        </attributes>
      </nodes>
      <edges xmi:id="_lhs_root_to_feature_c" source="_lhs_root_c" target="_lhs_feature_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel/features"/>
      </edges>
      <formula xsi:type="henshin:Not" xmi:id="_createClass_NAC">
        <child xsi:type="henshin:NestedCondition" xmi:id="_createClass_NAC_Child">
          <conclusion xmi:id="_createClass_NAC_Conclusion">
            <nodes xmi:id="_nac_root_c" name="root">
              <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel"/>
            </nodes>
            <nodes xmi:id="_nac_class_c" name="existingClass">
              <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//CRAClass"/>
              <attributes xmi:id="_nac_class_name" value="className">
                <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//NamedElement/name"/>
              </attributes>
            </nodes>
            <edges xmi:id="_nac_edge_c" source="_nac_root_c" target="_nac_class_c">
              <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel/classes"/>
            </edges>
          </conclusion>
          <mappings origin="_lhs_root_c" image="_nac_root_c"/>
        </child>
      </formula>
    </lhs>
    <rhs xmi:id="_createClass_RHS" name="Rhs">
      <nodes xmi:id="_rhs_root_c" name="root" outgoing="_rhs_edge_c _rhs_root_to_feature_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel"/>
      </nodes>
      <nodes xmi:id="_rhs_class_c" name="newClass" incoming="_rhs_feature_to_class_c _rhs_edge_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//CRAClass"/>
        <attributes xmi:id="_rhs_class_name" value="className">
          <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//NamedElement/name"/>
        </attributes>
      </nodes>
      <nodes xmi:id="_rhs_feature_c" name="feature" incoming="_rhs_root_to_feature_c" outgoing="_rhs_feature_to_class_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//Feature"/>
        <attributes xmi:id="_rhs_feature_name_c" value="featureName">
          <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//NamedElement/name"/>
        </attributes>
      </nodes>
      <edges xmi:id="_rhs_edge_c" source="_rhs_root_c" target="_rhs_class_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel/classes"/>
      </edges>
      <edges xmi:id="_rhs_root_to_feature_c" source="_rhs_root_c" target="_rhs_feature_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//ClassModel/features"/>
      </edges>
      <edges xmi:id="_rhs_feature_to_class_c" source="_rhs_feature_c" target="_rhs_class_c">
        <type href="http://momot.big.tuwien.ac.at/examples/icmt/architecture/1.0#//Feature/isEncapsulatedBy"/>
      </edges>
    </rhs>
    <mappings xmi:id="_map_root_c" origin="_lhs_root_c" image="_rhs_root_c"/>
    <mappings xmi:id="_map_feature_c" origin="_lhs_feature_c" image="_rhs_feature_c"/>
  </units>
